{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-set-resizable",
    "core:window:allow-center",
    "core:window:allow-set-min-size"
  ]
}
