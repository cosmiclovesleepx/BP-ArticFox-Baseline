{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Polar Ops",
  "version": "0.1.0",
  "identifier": "org.blackpolar.polarops",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Polar Ops",
        "width": 360,
        "height": 420,
        "minWidth": 360,
        "minHeight": 420,
        "resizable": false,
        "center": true,
        "decorations": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
